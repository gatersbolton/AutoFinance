WEBAPP_ENV=prod
WEBAPP_AUTH_REQUIRED=1
WEBAPP_ADMIN_PASSWORD=change-this-now
WEBAPP_ENABLE_LOCAL_WORKER=0
WEBAPP_QUEUE_BACKEND=local
WEBAPP_AUTO_RUN_UPLOAD_OCR=1
WEBAPP_UPLOAD_OCR_METHOD=cloud_first
WEBAPP_PROVIDER_PRIORITY=aliyun,tencent
WEBAPP_MAX_UPLOAD_BYTES=52428800
WEBAPP_JOB_TIMEOUT_SECONDS=5400
WEBAPP_OPERATION_TIMEOUT_SECONDS=5400
WEBAPP_WORKER_POLL_SECONDS=2
WEBAPP_WORKER_HEARTBEAT_STALE_SECONDS=90
WEBAPP_RUNTIME_ROOT=data/generated/web
WEBAPP_UPLOADS_ROOT=data/generated/web/uploads
WEBAPP_JOBS_ROOT=data/generated/web/jobs
WEBAPP_RESULTS_ROOT=data/generated/web/results
WEBAPP_LOGS_ROOT=data/generated/web/logs
WEBAPP_TEMPLATE_PATH=data/templates/会计报表.xlsx
WEBAPP_SECRET_PATH=data/secrets/secret
REDIS_URL=redis://redis:6379/0
NGINX_PORT=80
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
